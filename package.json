{
  "name": "goalkeeper",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram-first IPS-governed autonomous development control plane.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "smoke": "scripts/smoke_test.sh",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "fastify": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
